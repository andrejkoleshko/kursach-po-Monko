<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Профиль пользователя</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body class="bg-body">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
      <div class="container-fluid">
        <a href="/" class="navbar-brand fw-semibold text-decoration-none">
          Облачное хранилище документов
        </a>

        <div class="d-flex align-items-center gap-3">
          <span id="navbar-display-name" class="text-light fw-semibold"></span>

          <div class="d-flex align-items-center gap-2">
            <a href="/" class="btn btn-outline-light btn-sm">
              Документы
            </a>
            <button id="profile-logout-btn" class="btn btn-light btn-sm">
              Выйти
            </button>
          </div>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
          <div class="card shadow-sm border-0 profile-card">
            <div class="card-body">

              <div class="d-flex align-items-center mb-4 gap-3">
                <div class="profile-avatar rounded-circle d-flex align-items-center justify-content-center">
                  <span id="profile-avatar-initials" class="fw-semibold"></span>
                  <img id="profile-avatar-preview" class="rounded-circle border" />
                </div>
                <div>
                  <h5 class="mb-1" id="profile-display-name-title">Профиль</h5>
                  <div class="text-muted small" id="profile-username-line"></div>
                  <div class="text-muted small" id="profile-role-line"></div>
                </div>
              </div>

              <form id="profile-form">
                <div class="mb-3">
                  <label class="form-label">Отображаемое имя</label>
                  <input type="text" id="profile-display-name" class="form-control" />
                </div>

                <div class="mb-3">
                  <label class="form-label">Имя</label>
                  <input type="text" id="profile-first-name" class="form-control" />
                </div>

                <div class="mb-3">
                  <label class="form-label">Фамилия</label>
                  <input type="text" id="profile-last-name" class="form-control" />
                </div>

                <div class="mb-3">
                  <label class="form-label">Email (логин)</label>
                  <input type="email" id="profile-email" class="form-control" readonly />
                </div>

                <div class="mb-3">
                  <label class="form-label">Телефон</label>
                  <input type="tel" id="profile-phone" class="form-control" placeholder="+375..." />
                </div>

                <div class="mb-3">
                  <label class="form-label">Фото профиля</label>
                  <input type="file" id="profile-avatar-file" class="form-control" accept="image/*" />

                  <!-- 🔥 Кнопка удаления фото -->
                  <button type="button" id="delete-avatar-btn" class="btn btn-danger btn-sm mt-2">
                    Удалить фото
                  </button>
                </div>

                <div class="text-end">
                  <a href="/" class="btn btn-outline-secondary me-2">
                    Назад к документам
                  </a>
                  <button type="submit" class="btn btn-primary">
                    Сохранить
                  </button>
                </div>
              </form>

              <div id="profile-status" class="small text-muted mt-3" aria-live="polite"></div>

            </div>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="profile.js"></script>
  </body>
</html>