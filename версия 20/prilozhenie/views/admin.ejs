<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Админ-панель</title>

  <!-- Скрываем страницу до проверки роли -->
  <style>
    body {
      visibility: hidden;
    }
  </style>

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <!-- Bootstrap Icons -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
  >

  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- Контейнер для Bootstrap‑alert -->
  <div id="alert-container"
       class="position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index: 9999; width: 420px;">
  </div>

  <div class="admin-header">
    <h1>Админ-панель</h1>
    <a href="/" class="btn-back">Назад</a>
  </div>

  <!-- Таблица пользователей -->
  <table id="users-table" class="table table-bordered table-striped mt-3">
    <thead class="table-primary">
      <tr>
        <th>ID</th>
        <th>Имя</th>
        <th>Email</th>
        <th>Активирован</th>
        <th>Роль</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <!-- Лимит загрузки -->
  <<div id="limit-section" class="mt-4">
  <h2>Настройка лимита загрузки</h2>
  <label for="limitRange">Лимит (МБ):</label>
  <input type="range" id="limitRange" min="50" max="2000" step="50">
  <span id="limitValue"></span>
  <button id="saveLimit" class="btn btn-primary btn-sm ms-2">Сохранить</button>
</div>


  <script src="admin.js"></script>
</body>
</html>
